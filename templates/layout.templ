							<rect x="1152" y="149" width="3" height="2"/><rect x="1159" y="149" width="3" height="2"/>
							<rect x="1152" y="157" width="3" height="2"/><rect x="1159" y="157" width="3" height="2"/>
							<rect x="1152" y="165" width="3" height="2"/><rect x="1159" y="165" width="3" height="2"/>
							<rect x="1174" y="107" width="3" height="2"/><rect x="1180" y="107" width="3" height="2"/>
							<rect x="1174" y="115" width="3" height="2"/><rect x="1180" y="115" width="3" height="2"/>
							<rect x="1174" y="123" width="3" height="2"/><rect x="1180" y="123" width="3" height="2"/>
							<rect x="1174" y="131" width="3" height="2"/><rect x="1180" y="131" width="3" height="2"/>
							<rect x="1174" y="139" width="3" height="2"/><rect x="1180" y="139" width="3" height="2"/>
							<rect x="1174" y="147" width="3" height="2"/><rect x="1180" y="147" width="3" height="2"/>
							<rect x="1174" y="155" width="3" height="2"/><rect x="1180" y="155" width="3" height="2"/>
							<rect x="1198" y="119" width="3" height="2"/><rect x="1205" y="119" width="3" height="2"/>
							<rect x="1198" y="127" width="3" height="2"/><rect x="1205" y="127" width="3" height="2"/>
							<rect x="1198" y="135" width="3" height="2"/><rect x="1205" y="135" width="3" height="2"/>
							<rect x="1198" y="143" width="3" height="2"/><rect x="1205" y="143" width="3" height="2"/>
							<rect x="1198" y="151" width="3" height="2"/><rect x="1205" y="151" width="3" height="2"/>
							<rect x="1198" y="159" width="3" height="2"/><rect x="1205" y="159" width="3" height="2"/>
							<rect x="1198" y="167" width="3" height="2"/><rect x="1205" y="167" width="3" height="2"/>
						</g>
					</svg>
				</div>
				<div class="header-inner">
				<div class="bear-wrap">
					<picture>
						<source srcset="bear.webp" type="image/webp"/>
						<img src="bear.png" alt="The Big Blue Bear"/>
					</picture>
					<span class="bear-eye bear-eye-left" aria-hidden="true"></span>
					<span class="bear-eye bear-eye-right" aria-hidden="true"></span>
				</div>
				<div class="header-text">
					<p class="header-eyebrow">MyDenverCard</p>
					<h1>Free.</h1>
					<p class="header-sub">Where Denver kids get in free.</p>
					<div class="weather-chip-row"><div id="weather-chip" class="weather-chip"></div></div>
				</div>
				</div>
			</header>
			<main>
				{ children... }
			</main>
			<div class="mountains" aria-hidden="true">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 64" preserveAspectRatio="none" width="100%" height="64">
					<path fill="#c8d4ee" d="M0,64 L0,48 L90,18 L200,52 L310,14 L430,50 L540,8 L660,44 L770,20 L890,50 L1000,16 L1120,48 L1230,10 L1350,42 L1440,22 L1440,64 Z"/>
					<path fill="#dde5f5" d="M0,64 L0,56 L110,38 L230,58 L350,30 L470,54 L590,34 L710,58 L830,40 L950,60 L1070,32 L1190,55 L1310,36 L1440,52 L1440,64 Z"/>
				</svg>
			</div>
			<footer>
				Auto-updated weekly. Always verify with the venue before visiting.
				<br/>
				<a href="https://github.com/benhammondmusic/my-denver-card-free/issues" target="_blank" rel="noopener noreferrer">Found missing or wrong info? Report it.</a>
				<br/>
				<a href="https://benhammondmusic.tech" target="_blank" rel="noopener noreferrer" style="font-size:0.7rem; opacity:0.6;">benhammondmusic.tech</a>
			</footer>
			<div id="card-modal-overlay" class="modal-overlay" aria-hidden="true">
				<div class="modal-sheet">
					<div class="modal-content">
						<div class="modal-header">
							<h2 class="modal-title">myDenverCard</h2>
							<button class="modal-close" id="card-modal-close" aria-label="Close">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
									<line x1="18" y1="6" x2="6" y2="18"></line>
									<line x1="6" y1="6" x2="18" y2="18"></line>
								</svg>
							</button>
						</div>
						<p class="modal-notes" style="margin-bottom: 1.25rem;">The myDenverCard is a free pass issued by the City of Denver that gives youth free admission to museums, the zoo, botanic gardens, recreation centers, and pools across the city.</p>
						<div class="card-info-section">
							<p class="card-info-heading">Who qualifies</p>
							<ul class="card-info-list">
								<li>Denver residents in kindergarten through 12th grade</li>
								<li>Ages 5 to 18</li>
								<li>The card is free to sign up for</li>
							</ul>
						</div>
						<a href="https://apm.activecommunities.com/denver/Membership" class="card-cta-btn" target="_blank" rel="noopener noreferrer">Get a free myDenverCard</a>
						<div class="card-prime-section">
							<p class="card-info-heading">For older adults</p>
							<p class="modal-notes">Denver residents ages 60+ qualify for <strong>myDenverPrime</strong>, a free membership to all Denver rec centers and pools. Sign up in person at any rec center with proof of age and Denver residency.</p>
							<a href="https://www.denvergov.org/Government/Agencies-Departments-Offices/Agencies-Departments-Offices-Directory/Parks-Recreation/Activities-Programs/Active-Older-Adults/My-Denver-Prime" class="modal-action-btn" target="_blank" rel="noopener noreferrer" style="margin-top:0.5rem; display:inline-flex;">Learn about myDenverPrime</a>
						</div>
					</div>
				</div>
			</div>
			<script>
				if ('serviceWorker' in navigator) {
					navigator.serviceWorker.register('sw.js').catch(function(){});
				}
				(function () {
					var btn = document.getElementById('theme-toggle');
					if (!btn) return;
					var SUN = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
					var MOON = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
					function update() {
						var dark = document.documentElement.getAttribute('data-theme') === 'dark';
						btn.innerHTML = dark ? SUN : MOON;
						btn.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
					}
					btn.addEventListener('click', function () {
						var dark = document.documentElement.getAttribute('data-theme') === 'dark';
						var next = dark ? 'light' : 'dark';
						document.documentElement.setAttribute('data-theme', next);
						localStorage.setItem('mdc-theme', next);
						update();
					});
					update();
				})();
				// Bear eyes Easter egg: triple-tap/click the bear to light up his eyes and
				// optionally trigger a scrape. To enable scrape dispatch, create a
				// fine-grained GitHub PAT with Actions: write scope on this repo only.
				(function () {
					var SCRAPE_TOKEN = ''; // paste fine-grained PAT here
					var COOLDOWN_MS = 30 * 60 * 1000;
					var REPO = 'benhammondmusic/my-denver-card-free';
					var WORKFLOW = 'scrape.yml';

					var eyes = document.querySelectorAll('.bear-eye');
					var bearWrap = document.querySelector('.bear-wrap');
					if (!bearWrap) return;

					function lightUp() {
						eyes.forEach(function (e) { e.classList.add('lit'); });
						setTimeout(function () {
							eyes.forEach(function (e) { e.classList.remove('lit'); });
						}, 2500);
					}

					function canTrigger() {
						var last = parseInt(localStorage.getItem('mdc-scrape-ts') || '0', 10);
						return SCRAPE_TOKEN && (Date.now() - last > COOLDOWN_MS);
					}

					function triggerScrape() {
						localStorage.setItem('mdc-scrape-ts', String(Date.now()));
						fetch('https://api.github.com/repos/' + REPO + '/actions/workflows/' + WORKFLOW + '/dispatches', {
							method: 'POST',
							headers: {
								'Authorization': 'Bearer ' + SCRAPE_TOKEN,
								'Accept': 'application/vnd.github+json',
								'Content-Type': 'application/json'
							},
							body: JSON.stringify({ ref: 'main' })
						}).catch(function () {});
					}

					var tapCount = 0;
					var tapTimer = null;
					var lastTouch = 0;

					function handleTap() {
						tapCount++;
						clearTimeout(tapTimer);
						if (tapCount >= 3) {
							tapCount = 0;
							lightUp();
							if (canTrigger()) triggerScrape();
						} else {
							tapTimer = setTimeout(function () { tapCount = 0; }, 600);
						}
					}

					bearWrap.addEventListener('touchend', function (e) {
						e.preventDefault();
						lastTouch = Date.now();
						handleTap();
					}, { passive: false });

					bearWrap.addEventListener('click', function () {
						if (Date.now() - lastTouch < 500) return;
						handleTap();
					});
				})();

				(function () {
					var overlay = document.getElementById('card-modal-overlay');
					var openBtn = document.getElementById('card-info-btn');
					var closeBtn = document.getElementById('card-modal-close');
					function open() {
						if (!overlay) return;
						overlay.setAttribute('aria-hidden', 'false');
						overlay.classList.add('open');
						document.body.style.overflow = 'hidden';
						if (closeBtn) setTimeout(function () { closeBtn.focus(); }, 50);
					}
					function close() {
						if (!overlay) return;
						overlay.setAttribute('aria-hidden', 'true');
						overlay.classList.remove('open');
						document.body.style.overflow = '';
					}
					if (openBtn) openBtn.addEventListener('click', open);
					var heroCardLink = document.getElementById('hero-card-link');
					if (heroCardLink) heroCardLink.addEventListener('click', open);
					if (closeBtn) closeBtn.addEventListener('click', close);
					if (overlay) overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });
					document.addEventListener('keydown', function (e) {
						if (e.key === 'Escape' && overlay && overlay.classList.contains('open')) close();
					});

					// Swipe down to dismiss
					var sheet = overlay ? overlay.querySelector('.modal-sheet') : null;
					var content = overlay ? overlay.querySelector('.modal-content') : null;
					if (sheet) {
						var sy = 0, ly = 0, drag = false;
						sheet.addEventListener('touchstart', function (e) {
							sy = e.touches[0].clientY; ly = sy; drag = false;
						}, { passive: true });
						sheet.addEventListener('touchmove', function (e) {
							ly = e.touches[0].clientY;
							var dy = ly - sy;
							if (!drag && (!content || content.scrollTop === 0) && dy > 8) drag = true;
							if (drag && dy > 0) {
								sheet.style.transform = 'translateY(' + dy + 'px)';
								sheet.style.transition = 'none';
								e.preventDefault();
							}
						}, { passive: false });
						sheet.addEventListener('touchend', function () {
							if (!drag) return;
							var dy = ly - sy;
							sheet.style.transition = '';
							sheet.style.transform = '';
							drag = false;
							if (dy > 80) close();
						});
					}
				})();
			</script>
		</body>
	</html>
}
